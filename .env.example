# Copy to .env and fill in. NEVER commit .env (gitignored). Testnet only.

# Funded Monad testnet deployer key (0x-prefixed). No real funds — testnet MON only.
PRIVATE_KEY=0xyour_testnet_private_key

# Optional: override the RPC (e.g. a paid Alchemy/QuickNode backup under crowd load).
# Defaults to the public endpoint when unset.
RPC_URL=https://testnet-rpc.monad.xyz
